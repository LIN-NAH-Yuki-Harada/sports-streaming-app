# /opt/archive-worker/.env （chmod 600・gitに入れない・値は Vercel env からコピー）
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
RECORDINGS_DIR=/var/recordings

# ===== ライブ並走バックオフ（live-aware backoff・2026-07-22）=====
# ライブ配信中は重いアーカイブ変換/uploadを次tickへ見送り、帯域/ディスクをライブに譲る。
# 既定 OFF(opt-in)。まず未設定 or 0 のまま反映(挙動不変)→数日観測→ "1" で有効化。
LIVE_BACKOFF_ENABLED=0
# starvation回避の猶予(ms)。ended_atからこの時間以上待たされたらライブ並走でも強制処理。既定45分。
LIVE_BACKOFF_MAX_DEFER_MS=2700000
# 「生きているライブ」と数える started_at 新しさ上限(ms)。既定3h。長時間試合が多いなら 14400000=4h へ。
LIVE_ACTIVE_MAX_AGE_MS=10800000
