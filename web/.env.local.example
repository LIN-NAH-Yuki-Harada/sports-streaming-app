# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LiveKit
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Stripe（テスト環境）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_STREAMER=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# YouTube Data API（チームプラン向けアーカイブ連携）
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Storage (S3互換) — LiveKit Egress 録画MP4の一時保存先
# Supabase Dashboard > Project Settings > API > S3 Connection で取得
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-1
SUPABASE_STORAGE_RECORDINGS_BUCKET=recordings

# LiveKit Egress Webhook（Egress 完了時に Vercel 側に通知）
LIVEKIT_WEBHOOK_KEY=your-livekit-webhook-key

# Vercel Cron（stale配信の定期クリーンアップ用）
CRON_SECRET=your-cron-secret
